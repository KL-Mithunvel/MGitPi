# MGitPi SSH Credentials — Template
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to secrets/credentials.env and fill in your values.
# NEVER commit secrets/credentials.env — it is gitignored.
# ─────────────────────────────────────────────────────────────────────────────

# Path to your SSH private key.
# Leave blank to have setup.sh generate one automatically.
SSH_KEY_PATH=~/.ssh/id_ed25519

# Passphrase for your SSH key.
# Leave blank if your key has no passphrase.
SSH_PASSPHRASE=

# Your GitHub (or Gitea / GitLab) username.
GITHUB_USERNAME=your_username

# Hostname of the git server.
# Change to gitlab.com, your.gitea.server, etc. if not using GitHub.
GITHUB_HOST=github.com
